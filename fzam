#!/usr/bin/env bash

# FZAM - Fuzzy AppImage Manager | Manage AppImages on Linux.
# Depedencies: fzf, file, tree, gtk-update-icon-cache
# GitHub: https://github.com/sat3llite/fzam
# LICENSE: GNU General Public License v3.

# NOTE: The script and / or the author of the script do not take responsibility for any malware distributed as an AppImage.
# The user is advised to check for viruses in every AppImage they download and only download from reputable sources and not from a random GitHub page.
# The user may need to edit manually the .desktop file in case of any errors.

set -eu

## Variables
FMENU=(
    fzf 
    --layout=reverse \
    --exact \
    --border=bold \
    --border=rounded \
    --margin=5% \
    --multi \
    --color=dark \
    --height=92% \
    --info=hidden \
    --bind change:top \
    --bind enter:accept-or-print-query \
    --footer="FZAM | Fuzzy AppImage Manager v1.0" \
    --prompt
)

# Directory where AppImages are placed.
APPIMAGEDIR="$HOME/Applications"

# Directory where icons are placed
APPIMAGEICONDIR="$HOME/.local/share/icons/hicolor"

# Directory where desktop entries are placed in order for desktop environments to find them.
# Recommended: ~/.local/share/applications
APPIMAGEDESKTOPDIR="$HOME/.local/share/applications" 
verbose=0

## Functions ##

# Install / Integrate AppImage function.
amintegrate() {
    selection="$(find "$HOME" \( -path "${APPIMAGEDIR}" -o -path ~/.local/share/Trash -o -path ~/.cache \) -prune -o -type f -iname "*.AppImage" -print | "${FMENU[@]}" "Please type the location of the AppImage: ")"
    if [ -n "$selection" ]; then
	## AppImage
	
	# Check if selection is an AppImage
	amformat=$(file "${selection}" | awk -F ',' '{print $1}' | sed "s#${selection}: ##")
	case $amformat in
	    "ELF"*"LSB"*"executable")
                [[ "$verbose" -eq 1 ]] && echo "This file is an AppImage."
                ;;
	    *)
                echo "This file is not an AppImage."
                exit 1
                ;;
	esac
	chmod +x "$selection"
	amname="$(basename "$selection" | tr 'A-Z' 'a-z' | awk -F '[_-]' '{print $1}' | sed 's#.AppImage##I')"
	[[ "$verbose" -eq 1 ]] && echo "AppImage name is: ${amname}"
	amlocation="${APPIMAGEDIR}/${amname}.AppImage"
	mv -i "${selection}" "${amlocation}"
	
	${amlocation} --appimage-extract &> /dev/null || echo "This AppImage cannot be extracted."

	## AppImage Icon
	# AppDir Specification: "PNG or SVG icon located in the root directory. Can be used by e.g., thumbnailers, to display application icons rather than a generic filetype symbol. Should be in one of the standard image sizes, e.g., 128x128 or 256x256 pixels."
	if [[ -n "$(readlink -f squashfs-root/.DirIcon)" ]]; then
	    icon="$(readlink -f squashfs-root/.DirIcon)"
	    [[ "$verbose" -eq 1 ]] && echo "Found icon as $icon"

	    iconfmt="$(file "${icon}" | awk '{print $2}' | tr 'A-Z' 'a-z')"
	    [[ "$verbose" -eq 1 ]] && echo "Icon format is: $iconfmt"
	elif [[ -n $(find squashfs-root -maxdepth 1 -type f -iname "${amname}.*") ]]; then
	    icon="$(find squashfs-root -maxdepth 1 -type f -iname "${amname}.*")"
	    [[ "$verbose" -eq 1 ]] && echo "Found icon as $icon"


	    iconfmt="$(file "${icon}" | awk '{print $2}' | tr 'A-Z' 'a-z')"
	    [[ "$verbose" -eq 1 ]] && echo "Icon format is: $iconfmt"
	else
	    echo "Could not find icon."
	    icon="appimage"
	    iconfmt=""
	fi
	
	# Move icon to XDG-compliant directory.
	if [[ "$iconfmt" == "png" ]]; then
	    iconsize="$(file ${icon} | awk '{print $5}')"
	    [[ ! -d "$APPIMAGEICONDIR/${iconsize}x${iconsize}/apps" ]] && mkdir -p "${APPIMAGEICONDIR}/${iconsize}x${iconsize}/apps"
	    cp -i "${icon}" "${APPIMAGEICONDIR}/${iconsize}x${iconsize}/apps/${amname}.${iconfmt}" || echo "Could not copy icon file."
	    [[ "$verbose" -eq 1 ]] && echo "Copied icon file to ${APPIMAGEICONDIR}/${iconsize}x${iconsize}/apps"
	elif [[ "$iconfmt" == "svg" ]]; then
	    [[ ! -d "${APPIMAGEICONDIR}/scalable/apps" ]] && mkdir -p "${APPIMAGEICONDIR}/scalable/apps"
	    cp -i "${icon}" "${APPIMAGEICONDIR}/scalable/apps/${amname}.${iconfmt}" || echo "Could not copy icon file."
	    [[ "$verbose" -eq 1 ]] && echo "Copied icon file to ${APPIMAGEICONDIR}/scalable/apps"
	fi
	
	# Update icon cache.
	[[ ! -f "$APPIMAGEICONDIR/index.theme" ]] && [[ -f "/usr/share/icons/hicolor/index.theme" ]] && cp "/usr/share/icons/hicolor/index.theme" "$APPIMAGEICONDIR/index.theme"
	command -v gtk-update-icon-cache > /dev/null && gtk-update-icon-cache -f "$APPIMAGEICONDIR"

	## AppImage .desktop file
	## AppDir specification: "A desktop file located in the root directory, describing the payload application."
	finddesktop="$(find ./squashfs-root/ -maxdepth 1 -iname "*.desktop" | xargs -I {} readlink -f {})"
	for desktopfile in ${finddesktop}
	do
	    [[ "$verbose" -eq 1 ]] && echo "Found .desktop file as $desktopfile"
	    
	    sed -i "/Exec/s#${amname}#${amlocation}#I" "$desktopfile"
	    sed -i "/Exec/s#AppRun#${amlocation}#I" "$desktopfile"
	    sed -i "/Icon/s#=.*#=${amname}#I" "$desktopfile"
	    [[ "$verbose" -eq 1 ]] && echo "All sed substitutions were done."
	    
	    cp -i "${desktopfile}" "$APPIMAGEDESKTOPDIR" || echo "Could not copy .desktop file"
	    [[ "$verbose" -eq 1 ]] && echo "Copied .desktop file to $APPIMAGEDESKTOPDIR"
	done
	
	[[ -d "./squashfs-root" ]] && rm -rf squashfs-root
	[[ -d "./AppDir" ]] && rm -rf ./AppDir

	tput setaf 2 bold
	echo " ${selection} was successfully integrated."
	tput sgr0
    fi
}

## Delete / Uninstall AppImage.
amdelete() {
    selectiondel=""
    if [[ -d "${APPIMAGEDIR}" ]] && [[ -d "${APPIMAGEICONDIR}" ]]; then
        selectiondel="$(find "${APPIMAGEDIR}" -type f -iname "*.AppImage" -printf '%f\n' | sort | "${FMENU[@]}" "Choose an AppImage to remove: ")"
	if [[ -n "${selectiondel}" ]]; then
	    if [[ -f "${APPIMAGEDIR}/${selectiondel}" ]]; then
		amname="$(basename -s AppImage "${selectiondel}")"
		tput setaf 1 bold
		read -p "${selectiondel} will be uninstalled. Are you sure? [y/N] "
		tput sgr0
		if [[ $REPLY =~ ^[Yy] ]]; then
		    [[ "$verbose" -eq 1 ]] && echo "AppImage to be deleted: ${selectiondel}"

		    rm "${APPIMAGEDIR}/${selectiondel}" || echo "${selectiondel} was not found."
		    [[ "$verbose" -eq 1 ]] && echo "Deleted AppImage: ${selectiondel}"

		    founddesktop="$(grep -r "${selectiondel}" "${APPIMAGEDESKTOPDIR}" | awk -F ':' '{print $1}')"
		    if [[ -n "$founddesktop" ]]; then
			[[ "$verbose" -eq 1 ]] && echo "Found .desktop files: $(paste -sd, - <<< "${founddesktop[@]}")"
			for desktopfile in ${founddesktop}
			do
			    [[ -f $desktopfile && -n $desktopfile ]] && rm "$desktopfile"
			    [[ "$verbose" -eq 1 ]] && echo "Deleted AppImage .desktop file"
			done;
		    fi
		    foundicon="$(find "$APPIMAGEICONDIR" -type f -iname "${amname}*")"
		    if [[ -n "$foundicon" ]]; then
			rm "${foundicon}"
			[[ "$verbose" -eq 1 ]] && echo "Deleted icon: ${foundicon}"
		    else
			echo "No icon was found."
		    fi
		    tput setaf 1 bold
		    echo " ${selectiondel} was uninstalled."
		    tput sgr0
		else
		    tput setaf 1 bold
		    echo "Operation canceled"
		    tput sgr0
		fi
	    else
		tput setaf 1 bold
		echo "AppImage: ${selectiondel} was not found."
		tput sgr0
	    fi
	fi
    else
        tput setaf 1 bold
	echo " No AppImages were found."
	tput sgr0
    fi
}

# List installed AppImages.
amlist() {
    if [[ -d "${APPIMAGEDIR}" ]] && compgen -G "${APPIMAGEDIR}*.AppImage" &> /dev/null; then
	echo "$(tput setaf 6 bold)󰏖 AppImages currently installed:$(tput sgr0)"
	tree "${APPIMAGEDIR}" -P '*.AppImage' --prune --noreport | sed '1d'
    else
	echo "$(tput setaf 1 bold) No AppImages were found.$(tput sgr0)"
    fi
    tput setaf 4 bold; read -p 'Press any key to continue...' -n 1; tput sgr0
}

# Edit AppImage desktop entry (.desktop file).
amedit() {
        if [[ ! -f $HOME/.cache/fzam-edit ]]; then
                echo "By default fzam will open the .desktop file of an AppImage using the EDITOR variable."
                echo "This is currently set to: ${EDITOR}"
                echo "To override this run fzam like this: \$ EDITOR=PROGRAM fzam"
                touch ~/.cache/fzam-edit
        fi
        choice="$(grep -r -m 1 "\.AppImage" "${APPIMAGEDESKTOPDIR}" | sort | awk -F ":" '{print $1}' | "${FMENU[@]}" "Choose an AppImage entry to edit: ")"
        if [[ -n $choice ]]; then
                "${EDITOR}" "${choice}"
        fi
}

# Check for installed programs.
_checks() {
    if [ ! -d "$APPIMAGEDIR" ]; then
	echo "$APPIMAGEDIR directory does not exist. Creating it."
	mkdir -p "$APPIMAGEDIR"
    fi
    if [ ! -d "$APPIMAGEICONDIR" ]; then
	echo "$APPIMAGEICONDIR directory does not exist. Creating it."
	mkdir -p "$APPIMAGEICONDIR"
    fi
    if [ ! -d "$APPIMAGEDESKTOPDIR" ]; then
	echo "$APPIMAGEDESKTOPDIR directory does not exist. Creating it."
	mkdir -p "$APPIMAGEDESKTOPDIR"
    fi
    if ! grep -q "${APPIMAGEDIR}" <<< "$PATH"; then
	echo "${APPIMAGEDIR} is not set in the PATH variable."
    fi

    if ! command -v fzf > /dev/null; then
	echo "fzf could not be found. Make sure that it is installed."
	exit 1
    fi

    if ! command -v tree > /dev/null; then
	echo "tree could not be found. Make sure that it is installed."
	exit 1
    fi

    if ! command -v xargs > /dev/null; then
	echo "xargs could not be found. Make sure that it is installed."
	exit 1
    fi
}

# When called this function outputs the Help Text.
_help() {
    cat <<EOF
Description: Manage AppImages on Linux.
Usage: fzam [options]
       -d, --debug    Start fzam with verbose messages enabled. Useful for identifying problems with AppImage installation.
       -h, --help     Display this help message and exit.
       -l, --list     List all installed AppImages. Can be done through the fzam menu too.
       -v, --version  Output version information and exit.
EOF
}

# This function executes whether the script runs with the -d flag or not.
_maincmd() {
    options=(
	"Install/Integrate an AppImage"
	"Delete an AppImage"
	"Edit an AppImage Desktop Entry"
	"List Installed AppImages"
	"Quit"
    )
    choice="$(printf '%s\n' "${options[@]}" | "${FMENU[@]}" "What would you like to do? ")"
    case $choice in
	"${options[0]}")
		amintegrate
		;;
	"${options[1]}")
		amdelete
		;;
	"${options[2]}")
		amedit
		;;
	"${options[3]}")
		amlist
		;;
	"${options[4]}")
	        tput setaf 10 bold
		echo "Bye Bye!" 
		tput sgr0
		exit 0
		;;
    esac
    sleep 0.2
    _maincmd
}

# Main Function.
main() {
    _checks
    _arg="${1:-}"
    case "$_arg" in
	"")
	    tput setaf 3 bold
	    echo "FZAM | Fuzzy AppImage Manager v1.0"
	    echo "Manage AppImages on Linux."
	    tput sgr0
	    _maincmd
	    ;;
	-h | --help)
	    _help
	    ;;
	-l | --list)
	    amlist
	    ;;
	-d | --debug)
	    verbose=1
	    tput setaf 3 bold
	    echo "FZAM | Fuzzy AppImage Manager v1.0"
	    echo "Manage AppImages on Linux."
	    tput sgr0
	    tput setaf 13 bold
	    echo "Running in debug / verbose mode."
	    tput sgr0
	    _maincmd
	    ;;
	-v | --version)
	    tput setaf 12 bold
	    cat <<EOF
 _____ _____   _    __  __ 
|  ___|__  /  / \  |  \/  |
| |_    / /  / _ \ | |\/| |
|  _|  / /_ / ___ \| |  | |
|_|   /____/_/   \_\_|  |_|

Homepage: https://github.com/sat3llite/fzam
Report Issues at: https://github.com/sat3llite/fzam
EOF
	    tput sgr0
	    ;;
	*)
	    echo "Unknown argument: $1"
	    _help
	    ;;
    esac
}
main "$@"
